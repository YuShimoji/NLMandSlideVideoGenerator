<Window x:Class="NLMSlidePlugin.TimelinePlugin.CsvImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSVタイムラインインポート" 
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CSVファイル選択 -->
        <GroupBox Grid.Row="0" Header="CSVファイル" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CsvPathTextBox" Grid.Column="0" IsReadOnly="True" 
                         Text="{Binding CsvPath, Mode=TwoWay}"/>
                <Button x:Name="BrowseCsvButton" Grid.Column="1" Content="参照..." 
                        Margin="5,0,0,0" Padding="15,3" Click="BrowseCsvButton_Click"/>
            </Grid>
        </GroupBox>

        <!-- オプション -->
        <GroupBox Grid.Row="1" Header="インポートオプション" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <CheckBox x:Name="AddSubtitlesCheckBox" Content="字幕を追加（AudioItem使用時）"
                          IsChecked="{Binding AddSubtitles, Mode=TwoWay}" Margin="0,0,0,5"/>
                <TextBlock Text="音声はYMM4の台本インポートを使用してください。&#x0a;下の「台本CSV出力」で変換できます。"
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- (Row 2 is unused after audio directory removal) -->

        <!-- プレビュー/ログ -->
        <GroupBox Grid.Row="3" Header="インポート情報" Margin="0,0,0,10">
            <TabControl>
                <TabItem Header="プレビュー">
                    <DataGrid x:Name="PreviewDataGrid" AutoGenerateColumns="False" 
                              IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="行" Binding="{Binding LineNumber}" Width="40"/>
                            <DataGridTextColumn Header="話者" Binding="{Binding Speaker}" Width="100"/>
                            <DataGridTextColumn Header="テキスト" Binding="{Binding Text}" Width="*"/>
                            <DataGridTextColumn Header="音声" Binding="{Binding AudioFileName}" Width="80"/>
                            <DataGridTextColumn Header="長さ" Binding="{Binding Duration, StringFormat={}{0:F1}s}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="ログ/エラー">
                    <TextBox x:Name="LogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Auto" AcceptsReturn="True"
                             Text="{Binding LogContent, Mode=OneWay}"
                             FontFamily="Consolas" FontSize="11"/>
                </TabItem>
            </TabControl>
        </GroupBox>

        <!-- 進捗 -->
        <ProgressBar x:Name="ImportProgressBar" Grid.Row="4" Height="15" Margin="0,5"
                     Minimum="0" Maximum="100" Value="{Binding ProgressValue}"/>

        <!-- ステータス -->
        <TextBlock x:Name="StatusTextBlock" Grid.Row="5" Text="{Binding StatusMessage}" 
                   Margin="0,5" TextWrapping="Wrap"/>

        <!-- ボタン -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="PreviewButton" Content="プレビュー" Padding="20,5"
                    Margin="0,0,10,0" Click="PreviewButton_Click"/>
            <Button x:Name="ExportDaihonButton" Content="台本CSV出力" Padding="20,5"
                    Margin="0,0,10,0" Click="ExportDaihonButton_Click"
                    ToolTip="YMM4の台本形式（キャラ名,セリフ）に変換して保存"/>
            <Button x:Name="VoiceImportButton" Content="VoiceItem一括" Padding="20,5"
                    Margin="0,0,10,0" Click="VoiceImportButton_Click"
                    ToolTip="YMM4のキャラクター設定で音声合成し、VoiceItem+ImageItemを一括配置"/>
            <Button x:Name="ImportButton" Content="画像のみ" Padding="20,5"
                    Click="ImportButton_Click"
                    ToolTip="AudioItem+ImageItem+TextItemを配置（既存WAVがある場合）"/>
            <Button x:Name="CancelButton" Content="キャンセル" Padding="20,5"
                    Margin="10,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
