<Project>
  <PropertyGroup>
    <!-- YMM4のインストールフォルダ（末尾に\を含む） -->
    <!-- Example: D:\YukkuriMovieMaker_v4\ -->
    <!-- YMM4 v4.50+ は net10.0 が必要。.NET 10.0 SDK をインストールすること -->
    <YMM4DirPath>C:\Users\YourUserName\AppData\Local\YukkuriMovieMaker4\</YMM4DirPath>
  </PropertyGroup>

  <!-- Core project uses separate obj directory to avoid conflict with main plugin -->
  <PropertyGroup Condition="'$(MSBuildProjectName)' == 'NLMSlidePlugin.Core'">
    <BaseIntermediateOutputPath>obj\Core\</BaseIntermediateOutputPath>
    <MSBuildProjectExtensionsPath>obj\Core\</MSBuildProjectExtensionsPath>
  </PropertyGroup>
</Project>
