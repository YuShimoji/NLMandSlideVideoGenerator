<UserControl x:Class="NLMSlidePlugin.SettingsPlugin.CsvImportSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="12">
        <TextBlock Text="CSV Timeline Import"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,8"/>
        <TextBlock Text="CSVファイルと音声ファイルをタイムラインにインポートします。&#x0a;ツールメニューにも同じ機能があります。"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>
        <Button Content="CSVインポートダイアログを開く"
                Width="260" Height="36"
                HorizontalAlignment="Left"
                Click="OpenDialog_Click"/>
    </StackPanel>
</UserControl>
