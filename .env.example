# 環境設定ファイルのテンプレート
# 使用方法: このファイルを .env にコピーして、実際の値を設定してください

# アプリケーション設定
DEBUG=false
LOG_LEVEL=INFO

# LLM プロバイダー設定 (SP-043)
# LLM_PROVIDER: openai / claude / gemini / deepseek / mock
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# LLM_API_KEY は各プロバイダーの API キー。未設定時は下記の個別キーを使用
# LLM_API_KEY=your_llm_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google AI Studio Gemini API 設定
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube API 設定
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# Brave Search API (ソース収集用、旧Google Custom Searchから移行済み)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# 音声生成API設定
# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# Azure Speech Services
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here
AZURE_SPEECH_VOICE=ja-JP-NanamiNeural
AZURE_SPEECH_FORMAT=audio-48khz-192kbitrate-mono-mp3

# Google Cloud TTS
GOOGLE_CLOUD_TTS_KEY=your_google_cloud_tts_key_here

# データベース設定
DATABASE_URL=sqlite:///./nlm_video_generator.db

# Redis設定
REDIS_URL=redis://localhost:6379/0

# セキュリティ設定
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# 外部サービス設定
WEBHOOK_SECRET=your_webhook_secret_here

# プロジェクト設定
PROJECT_NAME=NLMandSlideVideoGenerator
OUTPUT_DIR=./data/output
TEMP_DIR=./data/temp

# TTS プロバイダ選択: none | elevenlabs | openai | azure | google_cloud
TTS_PROVIDER=none

# Google Slides OAuth ファイルパス
GOOGLE_CLIENT_SECRETS_FILE=./google_client_secret.json
GOOGLE_OAUTH_TOKEN_FILE=./token.json
